    <script>
        // ─── NAVBAR SCROLL ───
        const navbar = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
            navbar.classList.toggle('scrolled', window.scrollY > 80);
        }, { passive: true });

        // ─── HERO PARTICLES ───
        const particleContainer = document.getElementById('heroParticles');
        for (let i = 0; i < 25; i++) {
            const p = document.createElement('div');
            p.classList.add('particle');
            p.style.left = Math.random() * 100 + '%';
            p.style.width = p.style.height = (Math.random() * 3 + 1.5) + 'px';
            p.style.animationDuration = (Math.random() * 8 + 6) + 's';
            p.style.animationDelay = (Math.random() * 6) + 's';
            p.style.opacity = Math.random() * 0.4 + 0.1;
            particleContainer.appendChild(p);
        }

        // ─── SCROLL PROGRESS LINE (relative to timeline-container) ───
        const progressFill = document.getElementById('progressFill');
        const timelineContainer = document.querySelector('.timeline-container');

        function updateProgress() {
            const rect = timelineContainer.getBoundingClientRect();
            const containerTop = rect.top + window.pageYOffset;
            const containerHeight = timelineContainer.offsetHeight;
            const scrollTop = window.pageYOffset;
            const progress = Math.max(0, Math.min(1, (scrollTop - containerTop + window.innerHeight * 0.3) / containerHeight));
            progressFill.style.height = (progress * 100) + '%';
        }

        // ─── SECTION NODES ───
        const sections = document.querySelectorAll('.journey-section');
        const nodes = [
            document.getElementById('node-1'),
            document.getElementById('node-2'),
            document.getElementById('node-3'),
            document.getElementById('node-4'),
            document.getElementById('node-5'),
        ];

        function positionNodes() {
            const containerTop = timelineContainer.offsetTop;
            const containerHeight = timelineContainer.offsetHeight;
            sections.forEach((sec, i) => {
                if (!nodes[i]) return;
                const secMid = sec.offsetTop - containerTop + sec.offsetHeight / 2;
                const pct = (secMid / containerHeight) * 100;
                nodes[i].style.top = pct + '%';
            });
        }

        function updateNodes() {
            const fillHeight = parseFloat(progressFill.style.height) || 0;
            nodes.forEach((node) => {
                if (!node) return;
                const nodePos = parseFloat(node.style.top) || 0;
                node.classList.toggle('lit', fillHeight >= nodePos);
            });
        }

        // ─── REVEAL ANIMATIONS ───
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const sec = entry.target;
                    sec.querySelector('.journey-content')?.classList.add('active');
                    sec.querySelector('.polaroid-cluster')?.classList.add('active');
                    const polaroids = sec.querySelectorAll('.polaroid');
                    polaroids.forEach((p, i) => {
                        p.style.transition = `transform 0.5s cubic-bezier(0.25,0.8,0.25,1) ${i * 0.08}s, box-shadow 0.5s`;
                    });
                }
            });
        }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });

        sections.forEach(sec => observer.observe(sec));

        // ─── POLAROID TILT ───
        sections.forEach(sec => {
            const cluster = sec.querySelector('.polaroid-cluster');
            const polaroids = sec.querySelectorAll('.polaroid');
            cluster?.addEventListener('mousemove', (e) => {
                const rect = cluster.getBoundingClientRect();
                const cx = rect.left + rect.width / 2;
                const cy = rect.top + rect.height / 2;
                const dx = (e.clientX - cx) / rect.width;
                const dy = (e.clientY - cy) / rect.height;
                polaroids.forEach((p, i) => {
                    const baseRots = [-3, 4, 2, -5];
                    const r = baseRots[i] || 0;
                    p.style.transform = `rotate(${r}deg) rotateX(${dy * 8}deg) rotateY(${-dx * 8}deg) translateZ(${i * 4}px)`;
                    p.style.transition = 'transform 0.15s ease';
                });
            });
            cluster?.addEventListener('mouseleave', () => {
                const baseRots = [-3, 4, 2, -5];
                polaroids.forEach((p, i) => {
                    p.style.transform = `rotate(${baseRots[i]}deg)`;
                    p.style.transition = 'transform 0.5s ease';
                });
            });
        });

        // ─── SCROLL EVENT ───
        window.addEventListener('scroll', () => {
            updateProgress();
            updateNodes();
        }, { passive: true });

        window.addEventListener('resize', () => {
            positionNodes();
            updateProgress();
            updateNodes();
        });

        // Init
        setTimeout(() => {
            positionNodes();
            updateProgress();
            updateNodes();
        }, 200);
    </script>

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Discover India - Tourism Experiences | Atmanirbhar Yatra</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Jost:wght@300;400;500;600&display=swap"
        rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --orange: #ff6b35;
            --gold: #f7931e;
            --amber: #ffcc44;
            --dark: #060608;
            --dark2: #0d0d10;
            --dark3: #151518;
            --dark4: #1c1c20;
            --text-dim: #777;
            --text-mid: #aaa;
            --white: #f0f0f0;
            --glass: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.06);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Jost', sans-serif;
            background: var(--dark);
            color: var(--white);
            overflow-x: hidden;
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: var(--dark);
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, var(--orange), var(--gold));
            border-radius: 3px;
        }

        /* ─── NAVBAR ─── */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            padding: 1rem 3rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            background: rgba(6, 6, 8, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .navbar.scrolled {
            background: rgba(6, 6, 8, 0.95);
            padding: 0.7rem 3rem;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--orange);
            text-decoration: none;
        }

        .nav-logo img {
            width: 32px;
            height: 32px;
            filter: brightness(0) saturate(100%) invert(45%) sepia(76%) saturate(2468%) hue-rotate(346deg) brightness(101%) contrast(101%);
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 2.2rem;
        }

        .nav-links a {
            color: var(--text-mid);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 400;
            letter-spacing: 0.5px;
            transition: color 0.3s;
            position: relative;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 1.5px;
            background: linear-gradient(90deg, var(--orange), var(--gold));
            transition: width 0.3s;
        }

        .nav-links a:hover {
            color: var(--white);
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        .nav-links a.active {
            color: var(--orange);
        }

        .nav-links a.active::after {
            width: 100%;
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .nav-right a {
            color: var(--text-mid);
            font-size: 1.1rem;
            transition: color 0.3s;
            text-decoration: none;
        }

        .nav-right a:hover {
            color: var(--orange);
        }

        .nav-btn {
            background: linear-gradient(135deg, var(--orange), var(--gold));
            padding: 0.6rem 1.4rem;
            border-radius: 25px;
            color: #fff !important;
            font-weight: 600;
            font-size: 0.85rem;
            text-decoration: none;
            transition: all 0.3s;
        }

        .nav-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(255, 107, 53, 0.35);
        }

        /* ─── PROGRESS LINE (inside timeline-container) ─── */
        .timeline-container {
            position: relative;
        }

        .progress-line-track {
            position: absolute;
            left: 50%;
            top: 0;
            transform: translateX(-50%);
            width: 2px;
            height: 100%;
            background: rgba(255, 107, 53, 0.06);
            z-index: 50;
            pointer-events: none;
        }

        .progress-line-fill {
            width: 100%;
            height: 0%;
            background: linear-gradient(180deg, var(--orange), var(--gold), var(--amber));
            transition: height 0.05s linear;
            position: relative;
            border-radius: 0 0 2px 2px;
        }

        .progress-line-fill::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 50%;
            transform: translateX(-50%);
            width: 14px;
            height: 14px;
            background: var(--orange);
            border-radius: 50%;
            box-shadow: 0 0 20px var(--orange), 0 0 50px rgba(255, 107, 53, 0.4), 0 0 80px rgba(255, 107, 53, 0.15);
            animation: pulseDot 2s ease-in-out infinite;
        }

        @keyframes pulseDot {

            0%,
            100% {
                box-shadow: 0 0 20px var(--orange), 0 0 50px rgba(255, 107, 53, 0.4);
            }

            50% {
                box-shadow: 0 0 30px var(--orange), 0 0 70px rgba(255, 107, 53, 0.5), 0 0 100px rgba(255, 107, 53, 0.2);
            }
        }

        .line-node {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            width: 10px;
            height: 10px;
            background: var(--dark3);
            border: 2px solid rgba(255, 107, 53, 0.2);
            border-radius: 50%;
            z-index: 51;
            pointer-events: none;
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .line-node.lit {
            background: var(--orange);
            border-color: var(--orange);
            box-shadow: 0 0 16px var(--orange), 0 0 40px rgba(255, 107, 53, 0.3);
            transform: translateX(-50%) scale(1.3);
        }

        /* ─── HERO ─── */
        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            position: relative;
            overflow: hidden;
            background: var(--dark);
        }

        .hero-bg {
            position: absolute;
            inset: 0;
            background: url('https://images.unsplash.com/photo-1524492412937-b28074a5d7da?w=1600') center/cover;
            opacity: 0.15;
            transform: scale(1.1);
            animation: heroBgDrift 20s ease-in-out infinite alternate;
        }

        @keyframes heroBgDrift {
            from {
                transform: scale(1.1) translateY(0);
            }

            to {
                transform: scale(1.15) translateY(-20px);
            }
        }

        .hero-grain {
            position: absolute;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
            opacity: 0.5;
            pointer-events: none;
        }

        .hero-vignette {
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at center, transparent 40%, var(--dark) 100%);
            pointer-events: none;
        }

        /* Floating particles */
        .hero-particles {
            position: absolute;
            inset: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .particle {
            position: absolute;
            width: 3px;
            height: 3px;
            background: var(--orange);
            border-radius: 50%;
            opacity: 0;
            animation: floatParticle linear infinite;
        }

        @keyframes floatParticle {
            0% {
                opacity: 0;
                transform: translateY(100vh) scale(0);
            }

            10% {
                opacity: 0.6;
            }

            90% {
                opacity: 0.6;
            }

            100% {
                opacity: 0;
                transform: translateY(-20vh) scale(1);
            }
        }

        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 860px;
            padding: 20px;
        }

        .hero-eyebrow {
            font-size: 0.7rem;
            letter-spacing: 6px;
            text-transform: uppercase;
            color: var(--orange);
            margin-bottom: 24px;
            opacity: 0;
            animation: fadeUp 1s 0.3s forwards;
        }

        .hero h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 6.5rem;
            font-weight: 600;
            line-height: 1;
            margin-bottom: 28px;
            opacity: 0;
            animation: fadeUp 1s 0.6s forwards;
        }

        .hero h1 em {
            font-style: italic;
            background: linear-gradient(135deg, #ff6b35, #f7931e, #ffcc44, #ff6b35);
            background-size: 300% 300%;
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shimmer 4s ease-in-out infinite;
        }

        @keyframes shimmer {

            0%,
            100% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }
        }

        .hero p {
            font-size: 1.1rem;
            color: var(--text-dim);
            letter-spacing: 0.5px;
            line-height: 1.7;
            max-width: 560px;
            margin: 0 auto;
            opacity: 0;
            animation: fadeUp 1s 0.9s forwards;
        }

        .hero-ornament {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
            margin-top: 36px;
            opacity: 0;
            animation: fadeUp 1s 1.1s forwards;
        }

        .hero-ornament-line {
            width: 60px;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255, 107, 53, 0.4), transparent);
        }

        .hero-ornament-diamond {
            width: 8px;
            height: 8px;
            background: var(--orange);
            transform: rotate(45deg);
            box-shadow: 0 0 12px rgba(255, 107, 53, 0.5);
        }

        .scroll-cue {
            position: absolute;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            opacity: 0;
            animation: fadeUp 1s 1.4s forwards;
        }

        .scroll-cue span {
            font-size: 0.6rem;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: var(--text-dim);
        }

        .scroll-cue-line {
            width: 1px;
            height: 50px;
            background: linear-gradient(180deg, var(--orange), transparent);
            animation: scrollPulse 2s infinite;
        }

        @keyframes scrollPulse {
            0% {
                transform: scaleY(0);
                transform-origin: top;
            }

            50% {
                transform: scaleY(1);
                transform-origin: top;
            }

            51% {
                transform: scaleY(1);
                transform-origin: bottom;
            }

            100% {
                transform: scaleY(0);
                transform-origin: bottom;
            }
        }

        /* ─── JOURNEY SECTIONS ─── */
        .journey-section {
            display: flex;
            align-items: center;
            min-height: 100vh;
            padding: 140px 8%;
            position: relative;
            gap: 80px;
        }

        .journey-section:nth-of-type(even) {
            flex-direction: row-reverse;
        }

        /* Ambient glow */
        .journey-section::before {
            content: '';
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255, 107, 53, 0.04) 0%, transparent 70%);
            pointer-events: none;
            z-index: 0;
        }

        .journey-section:nth-child(odd)::before {
            right: -100px;
            top: 20%;
        }

        .journey-section:nth-child(even)::before {
            left: -100px;
            bottom: 20%;
        }

        /* ─── POLAROID CLUSTER ─── */
        .polaroid-cluster {
            flex: 1;
            position: relative;
            height: 600px;
            opacity: 0;
            transform: translateY(60px);
            transition: opacity 1.2s cubic-bezier(0.16, 1, 0.3, 1), transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .polaroid-cluster.active {
            opacity: 1;
            transform: translateY(0);
        }

        .polaroid {
            position: absolute;
            background: #fff;
            padding: 10px 10px 38px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6), 0 4px 12px rgba(0, 0, 0, 0.3);
            border-radius: 3px;
            transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.5s;
            cursor: pointer;
        }

        .polaroid::before {
            content: '';
            position: absolute;
            inset: -2px;
            background: linear-gradient(135deg, rgba(255, 107, 53, 0.0), rgba(247, 147, 30, 0.15), rgba(255, 107, 53, 0.0));
            border-radius: 4px;
            z-index: -1;
            opacity: 0;
            transition: opacity 0.5s;
        }

        .polaroid:hover::before {
            opacity: 1;
        }

        .polaroid:hover {
            box-shadow: 0 30px 80px rgba(0, 0, 0, 0.7), 0 0 40px rgba(255, 107, 53, 0.15);
            z-index: 10 !important;
        }

        .polaroid img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .polaroid-caption {
            position: absolute;
            bottom: 10px;
            left: 0;
            right: 0;
            text-align: center;
            font-family: 'Cormorant Garamond', serif;
            font-size: 0.8rem;
            color: #555;
            font-style: italic;
        }

        .polaroid-1 {
            width: 240px;
            height: 200px;
            top: 0;
            left: 20px;
            transform: rotate(-3deg);
            z-index: 4;
        }

        .polaroid-2 {
            width: 240px;
            height: 200px;
            top: 10px;
            right: 20px;
            transform: rotate(4deg);
            z-index: 3;
        }

        .polaroid-3 {
            width: 240px;
            height: 200px;
            bottom: 60px;
            left: 0;
            transform: rotate(2deg);
            z-index: 2;
        }

        .polaroid-4 {
            width: 240px;
            height: 200px;
            bottom: 50px;
            right: 30px;
            transform: rotate(-5deg);
            z-index: 1;
        }

        .journey-section:nth-child(2) .polaroid-1 {
            transform: rotate(-4deg);
        }

        .journey-section:nth-child(2) .polaroid-2 {
            transform: rotate(3deg);
        }

        .journey-section:nth-child(2) .polaroid-3 {
            transform: rotate(-2deg);
        }

        .journey-section:nth-child(2) .polaroid-4 {
            transform: rotate(5deg);
        }

        .journey-section:nth-child(3) .polaroid-1 {
            transform: rotate(5deg);
        }

        .journey-section:nth-child(3) .polaroid-2 {
            transform: rotate(-3deg);
        }

        .journey-section:nth-child(3) .polaroid-3 {
            transform: rotate(4deg);
        }

        .journey-section:nth-child(3) .polaroid-4 {
            transform: rotate(-2deg);
        }

        .journey-section:nth-child(4) .polaroid-1 {
            transform: rotate(-2deg);
        }

        .journey-section:nth-child(4) .polaroid-2 {
            transform: rotate(5deg);
        }

        .journey-section:nth-child(4) .polaroid-3 {
            transform: rotate(-4deg);
        }

        .journey-section:nth-child(4) .polaroid-4 {
            transform: rotate(3deg);
        }

        /* ─── TEXT CONTENT ─── */
        .journey-content {
            flex: 1;
            opacity: 0;
            transform: translateY(50px);
            transition: opacity 1s 0.25s ease, transform 1s 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .journey-content.active {
            opacity: 1;
            transform: translateY(0);
        }

        .journey-number-badge {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
        }

        .badge-num {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--orange), var(--gold));
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.4rem;
            font-weight: 600;
            box-shadow: 0 8px 28px rgba(255, 107, 53, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.2);
            animation: badgePulse 3s ease-in-out infinite;
        }

        @keyframes badgePulse {

            0%,
            100% {
                box-shadow: 0 8px 28px rgba(255, 107, 53, 0.4);
            }

            50% {
                box-shadow: 0 8px 36px rgba(255, 107, 53, 0.6), 0 0 60px rgba(255, 107, 53, 0.15);
            }
        }

        .badge-line {
            width: 50px;
            height: 1px;
            background: linear-gradient(90deg, var(--orange), transparent);
        }

        .journey-category {
            font-size: 0.7rem;
            letter-spacing: 5px;
            text-transform: uppercase;
            color: var(--orange);
            margin-bottom: 14px;
        }

        .journey-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 3.8rem;
            font-weight: 600;
            line-height: 1.08;
            margin-bottom: 22px;
        }

        .journey-description {
            font-size: 0.95rem;
            line-height: 1.9;
            color: var(--text-dim);
            margin-bottom: 30px;
            max-width: 480px;
        }

        .journey-highlights {
            list-style: none;
            margin-bottom: 38px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .journey-highlights li {
            font-size: 0.85rem;
            color: var(--text-mid);
            padding-left: 22px;
            position: relative;
            line-height: 1.5;
        }

        .journey-highlights li::before {
            content: '';
            position: absolute;
            left: 0;
            top: 7px;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--orange);
            box-shadow: 0 0 8px rgba(255, 107, 53, 0.4);
        }

        .journey-btn {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            padding: 15px 32px;
            border: 1px solid rgba(255, 107, 53, 0.3);
            color: var(--white);
            text-decoration: none;
            border-radius: 6px;
            font-size: 0.8rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(4px);
            background: rgba(255, 107, 53, 0.05);
        }

        .journey-btn::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, var(--orange), var(--gold));
            transform: translateX(-100%);
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            z-index: -1;
        }

        .journey-btn:hover::before {
            transform: translateX(0);
        }

        .journey-btn:hover {
            border-color: transparent;
            box-shadow: 0 12px 36px rgba(255, 107, 53, 0.3);
            transform: translateY(-2px);
        }

        .journey-btn i {
            transition: transform 0.3s;
        }

        .journey-btn:hover i {
            transform: translateX(4px);
        }

        /* Dividers */
        .section-divider {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 8%;
            gap: 16px;
        }

        .section-divider-line {
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255, 107, 53, 0.15), transparent);
        }

        .section-divider-diamond {
            width: 8px;
            height: 8px;
            background: rgba(255, 107, 53, 0.3);
            transform: rotate(45deg);
            transition: all 0.3s;
        }

        /* bg numbers */
        .section-bg-num {
            position: absolute;
            font-family: 'Cormorant Garamond', serif;
            font-size: 25vw;
            font-weight: 600;
            color: rgba(255, 107, 53, 0.015);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none;
            user-select: none;
            line-height: 1;
        }

        /* ─── FOOTER ─── */
        .footer {
            background: linear-gradient(180deg, var(--dark), #040405);
            padding: 80px 8% 40px;
            position: relative;
            border-top: 1px solid rgba(255, 107, 53, 0.08);
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: 60px;
            margin-bottom: 60px;
        }

        .footer-brand {}

        .footer-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--orange);
            margin-bottom: 16px;
            text-decoration: none;
        }

        .footer-logo img {
            width: 30px;
            height: 30px;
            filter: brightness(0) saturate(100%) invert(45%) sepia(76%) saturate(2468%) hue-rotate(346deg) brightness(101%) contrast(101%);
        }

        .footer-brand p {
            color: var(--text-dim);
            font-size: 0.9rem;
            line-height: 1.7;
            max-width: 320px;
        }

        .footer-col h4 {
            font-size: 0.75rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--orange);
            margin-bottom: 20px;
        }

        .footer-col ul {
            list-style: none;
        }

        .footer-col li {
            margin-bottom: 10px;
        }

        .footer-col a {
            color: var(--text-dim);
            text-decoration: none;
            font-size: 0.9rem;
            transition: color 0.3s;
        }

        .footer-col a:hover {
            color: var(--white);
        }

        .footer-social {
            display: flex;
            gap: 14px;
            margin-top: 20px;
        }

        .footer-social a {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            border: 1px solid rgba(255, 107, 53, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-dim);
            font-size: 0.9rem;
            transition: all 0.3s;
        }

        .footer-social a:hover {
            background: var(--orange);

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Atmanirbhar Yatra</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Playfair+Display:wght@400;700&display=swap"
        rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background: #0a0a0a;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
        }

        .container {
            display: flex;
            max-width: 1400px;
            width: 95%;
            min-height: 700px;
            background: #111111;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
            overflow: hidden;
            border: 1px solid #222;
        }

        /* Left Image Section - Carousel */
        .image-section {
            flex: 1.2;
            position: relative;
            min-height: 700px;
            overflow: hidden;
        }

        .carousel {
            position: relative;
            width: 100%;
            height: 100%;
        }

        .carousel-slide {
            position: absolute;
            width: 100%;
            height: 100%;
            opacity: 0;
            transition: opacity 1.5s ease-in-out;
            background-size: cover;
            background-position: center;
        }

        .carousel-slide.active {
            opacity: 1;
        }

        .carousel-slide::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(255, 107, 53, 0.3), rgba(10, 10, 10, 0.7));
            z-index: 1;
        }

        .slide-content {
            position: absolute;
            bottom: 50px;
            left: 40px;
            right: 40px;
            z-index: 2;
            color: white;
        }

        .slide-content h2 {
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 12px;
            color: white;
            text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.6);
        }

        .slide-content p {
            font-size: 1rem;
            color: #f0f0f0;
            line-height: 1.5;
            text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.5);
        }

        .carousel-indicators {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 3;
            display: flex;
            gap: 10px;
        }

        .indicator {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .indicator.active {
            background: linear-gradient(135deg, #ff6b35, #f7931e);
            width: 35px;
            border-radius: 6px;
        }

        /* Right Form Section */
        .form-section {
            flex: 1;
            padding: 60px 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: #0a0a0a;
            max-height: 700px;
            overflow-y: auto;
        }

        .form-container {
            max-width: 450px;
            width: 100%;
            margin: 0 auto;
        }

        .form-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .brand-logo {
            font-size: 2rem;
            font-weight: 700;
            color: #ff6b35;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .brand-logo i {
            color: #ff6b35;
        }

        .form-title {
            font-family: 'Playfair Display', serif;
            color: white;
            font-size: 2.8rem;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .form-subtitle {
            color: #888;
            font-size: 1rem;
        }

        .form-toggle {
            display: flex;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            padding: 6px;
            margin-bottom: 30px;
            border: 1px solid #222;
        }

        .toggle-btn {
            flex: 1;
            padding: 12px;
            background: transparent;
            border: none;
            color: #888;
            font-size: 1rem;
            font-weight: 600;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .toggle-btn.active {
            background: linear-gradient(135deg, #ff6b35, #f7931e);
            color: white;
        }

        .form {
            opacity: 1;
            transform: translateX(0);
            transition: all 0.3s ease;
        }

        .form.hidden {
            opacity: 0;
            transform: translateX(20px);
            position: absolute;
            pointer-events: none;
        }

        .form-group {
            margin-bottom: 22px;
            position: relative;
        }

        .form-row {
            display: flex;
            gap: 15px;
        }

        .form-row .form-group {
            flex: 1;
        }

        .form-input,
        .form-select {
            width: 100%;
            padding: 14px 18px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid #333;
            border-radius: 8px;
            color: white;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            font-family: 'Montserrat', sans-serif;
        }

        .form-input:focus,
        .form-select:focus {
            outline: none;
            border-color: #ff6b35;
            background: rgba(255, 255, 255, 0.05);
        }

        .form-input::placeholder {
            color: #666;
        }

        .form-select {
            cursor: pointer;
        }

        .form-select option {
            background: #111111;
            color: white;
            padding: 15px;
        }

        .form-btn {
            width: 100%;
            padding: 17px;
            background: linear-gradient(135deg, #ff6b35, #f7931e);
            border: none;
            border-radius: 12px;
            color: white;
            font-size: 1.05rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin: 25px 0;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .form-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(255, 107, 53, 0.4);
        }

        .forgot-password {
            text-align: center;
            margin-top: 20px;
        }

        .forgot-password a {
            color: #ff6b35;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: color 0.3s ease;
        }

        .forgot-password a:hover {
            color: #f7931e;
        }

        .social-login {
            margin-top: 35px;
            text-align: center;
        }

        .social-login p {
            color: #666;
            margin-bottom: 20px;
            position: relative;
            font-size: 0.9rem;
        }

        .social-login p::before,
        .social-login p::after {
            content: '';
            position: absolute;
            top: 50%;
            width: 38%;
            height: 1px;
            background: rgba(255, 107, 53, 0.2);
        }

        .social-login p::before {
            left: 0;
        }

        .social-login p::after {
            right: 0;
        }

        .social-buttons {
            display: flex;
            gap: 15px;
        }

        .social-btn {
            flex: 1;
            padding: 14px;
            border: 2px solid rgba(255, 107, 53, 0.2);
            border-radius: 12px;
            background: transparent;
            color: #e0e0e0;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            font-weight: 500;
        }

        .social-btn:hover {
            border-color: #ff6b35;
            background: rgba(255, 107, 53, 0.1);
            transform: translateY(-2px);
        }

        .social-btn i {
            font-size: 1.2rem;
        }

        .message {
            padding: 14px;
            border-radius: 10px;
            margin-bottom: 20px;
            text-align: center;
            font-size: 0.95rem;
        }

        .message.error {
            background: rgba(220, 38, 38, 0.1);
            border: 2px solid rgba(220, 38, 38, 0.3);
            color: #ff6b6b;
        }

        .message.success {
            background: rgba(34, 197, 94, 0.1);
            border: 2px solid rgba(34, 197, 94, 0.3);
            color: #6ee7b7;
        }

        @media (max-width: 1024px) {
            .container {
                flex-direction: column;
                max-width: 600px;
                min-height: auto;
            }

            .image-section {
                min-height: 350px;
            }

            .slide-content h2 {
                font-size: 2rem;
            }

            .form-section {
                padding: 50px 30px;
                max-height: none;
            }
        }

        @media (max-width: 640px) {
            .container {
                border-radius: 0;
                width: 100%;
                min-height: 100vh;
            }

            .image-section {
                min-height: 250px;
            }

            .slide-content {
                left: 25px;
                right: 25px;
                bottom: 30px;
            }

            .slide-content h2 {
                font-size: 1.5rem;
            }

            .form-title {
                font-size: 2rem;
            }

            .form-section {
                padding: 40px 25px;
            }

            .form-row {
                flex-direction: column;
            }
        }

        /* Scrollbar Styling */
        .form-section::-webkit-scrollbar {
            width: 6px;
        }

        .form-section::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.03);
        }

        .form-section::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, #ff6b35, #f7931e);
            border-radius: 10px;
        }
    </style>
</head>

<body>
    <div class="container">
        <!-- Left Side - Image Carousel -->
        <div class="image-section">
            <div class="carousel">
                <div class="carousel-slide active"
                    style="background-image: url('https://images.unsplash.com/photo-1564507592333-c60657eea523?w=1200');">
                    <div class="slide-content">
                        <h2>Taj Mahal, Agra</h2>
                        <p>Experience the eternal symbol of love - one of the Seven Wonders of the World</p>
                    </div>
                </div>
                <div class="carousel-slide"
                    style="background-image: url('https://images.unsplash.com/photo-1599661046289-e31897846e41?w=1200');">
                    <div class="slide-content">
                        <h2>Jaipur - The Pink City</h2>
                        <p>Explore royal palaces, vibrant bazaars, and majestic forts in Rajasthan's capital</p>
                    </div>
                </div>
                <div class="carousel-slide"
                    style="background-image: url('https://images.unsplash.com/photo-1570168007204-dfb528c6958f?w=1200');">
                    <div class="slide-content">
                        <h2>Mumbai - City of Dreams</h2>
                        <p>Gateway of India, Marine Drive, and the bustling heart of Bollywood</p>
                    </div>
                </div>
                <div class="carousel-slide"
                    style="background-image: url('https://images.unsplash.com/photo-1626621341517-bbf3d9990a23?w=1200');">
                    <div class="slide-content">
                        <h2>Ladakh - Land of High Passes</h2>
                        <p>Pristine lakes, Buddhist monasteries, and breathtaking Himalayan landscapes</p>
                    </div>
                </div>
            </div>
            <div class="carousel-indicators">
                <div class="indicator active" data-slide="0"></div>
                <div class="indicator" data-slide="1"></div>
                <div class="indicator" data-slide="2"></div>
                <div class="indicator" data-slide="3"></div>
            </div>
        </div>

        <!-- Right Side - Forms Section -->
        <div class="form-section">
            <div class="form-container">
                <div class="form-header">
                    <div class="brand-logo">
                        <i class="fas fa-plane-departure"></i>
                        Atmanirbhar Yatra
                    </div>
                    <h1 class="form-title">Welcome Back</h1>
                    <p class="form-subtitle">Login to your account</p>
                </div>

                <!-- Form Toggle Buttons -->
                <div class="form-toggle">
                    <button class="toggle-btn active" onclick="showLogin()">Login</button>
                    <button class="toggle-btn" onclick="showSignup()">Sign Up</button>
                </div>

                <!-- Login Form -->
                <form id="loginForm" class="form" action="/login" method="POST">
                    <div id="messageContainer"></div>
                    <div class="form-group">
                        <input type="email" class="form-input" name="email" placeholder="Email Address" required>
                    </div>
                    <div class="form-group">
                        <input type="password" class="form-input" name="password" placeholder="Password" required>
                    </div>
                    <button type="submit" class="form-btn">
                        <i class="fas fa-sign-in-alt"></i> Login to Your Account
                    </button>
                    <div class="forgot-password">
                        <a href="/forgot-password">Forgot your password?</a>
                    </div>
                </form>

                <!-- Signup Form -->
                <form id="signupForm" class="form hidden" action="/signup" method="POST">
                    <div class="form-row">
                        <div class="form-group">
                            <input type="text" class="form-input" name="name" placeholder="Full Name" required>
                        </div>
                        <div class="form-group">
                            <select class="form-select" name="gender" required>
                                <option value="">Select Gender</option>
                                <option value="male">Male</option>
                                <option value="female">Female</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <input type="email" class="form-input" name="email" placeholder="Email Address" required>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <input type="tel" class="form-input" name="phone" placeholder="Phone (10 digits)"
                                pattern="[0-9]{10}" required>
                        </div>
                        <div class="form-group">
                            <select class="form-select" name="country" required>
                                <option value="">Select Country</option>
                                <option value="India">India</option>
                                <option value="USA">United States</option>
                                <option value="UK">United Kingdom</option>
                                <option value="Canada">Canada</option>
                                <option value="Australia">Australia</option>
                                <option value="Germany">Germany</option>
                                <option value="France">France</option>
                                <option value="Japan">Japan</option>
                                <option value="Singapore">Singapore</option>
                                <option value="UAE">United Arab Emirates</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <input type="password" class="form-input" name="password"
                                placeholder="Create Password (min 4 chars)" minlength="4" required>
                        </div>
                        <div class="form-group">
                            <input type="password" class="form-input" name="confirmPassword"
                                placeholder="Confirm Password" required>
                        </div>
                    </div>
                    <button type="submit" class="form-btn">
                        <i class="fas fa-user-plus"></i> Create Your Account
                    </button>
                </form>

                <!-- Social Login Options -->
                <div class="social-login">
                    <p>Or continue with</p>
                    <div class="social-buttons">
                        <button class="social-btn" onclick="socialLogin('google')">
                            <i class="fab fa-google"></i> Google
                        </button>
                        <button class="social-btn" onclick="socialLogin('facebook')">
                            <i class="fab fa-facebook-f"></i> Facebook
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Carousel functionality
        let currentSlide = 0;
        const slides = document.querySelectorAll('.carousel-slide');
        const indicators = document.querySelectorAll('.indicator');

        function showSlide(index) {
            slides.forEach(slide => slide.classList.remove('active'));
            indicators.forEach(ind => ind.classList.remove('active'));

            currentSlide = index;
            slides[currentSlide].classList.add('active');
            indicators[currentSlide].classList.add('active');
        }

        function nextSlide() {
            currentSlide = (currentSlide + 1) % slides.length;
            showSlide(currentSlide);
        }

        // Auto-advance carousel
        setInterval(nextSlide, 5000);

        // Indicator clicks
        indicators.forEach((indicator, index) => {
            indicator.addEventListener('click', () => showSlide(index));
        });

        // Display error/success messages
        window.addEventListener('load', function () {
            const urlParams = new URLSearchParams(window.location.search);
            const error = urlParams.get('error');
            const success = urlParams.get('success');

            const messageContainer = document.getElementById('messageContainer');

            if (error) {
                const errorMessages = {
                    'passwords_dont_match': 'Passwords do not match!',
                    'email_already_exists': 'An account with this email already exists.',
                    'signup_failed': 'Signup failed. Please try again.',
                    'invalid_credentials': 'Invalid email or password.',
                    'use_google': 'This account uses Google sign-in. Please use "Continue with Google".',
                    'login_failed': 'Login failed. Please try again.',
                    'oauth_failed': 'Social login failed. Please try again.',
                    'user_not_found': 'No account found with this email.',
                    'resend_failed': 'Failed to resend verification email.'
                };

                const message = errorMessages[error] || 'An error occurred.';
                messageContainer.innerHTML = `<div class="message error">${message}</div>`;
            }

            if (success) {
                const successMessages = {
                    'already_verified': 'Your email is already verified! You can log in.'
                };

                const message = successMessages[success] || 'Success!';
                messageContainer.innerHTML = `<div class="message success">${message}</div>`;
            }
        });

        // Toggle between login and signup forms
        function showLogin() {
            const loginForm = document.getElementById('loginForm');
            const signupForm = document.getElementById('signupForm');
            const toggleBtns = document.querySelectorAll('.toggle-btn');

            loginForm.classList.remove('hidden');
            signupForm.classList.add('hidden');

            toggleBtns[0].classList.add('active');
            toggleBtns[1].classList.remove('active');

            document.querySelector('.form-title').textContent = 'Welcome Back';
            document.querySelector('.form-subtitle').textContent = 'Start your journey with us';
        }

        function showSignup() {
            const loginForm = document.getElementById('loginForm');
            const signupForm = document.getElementById('signupForm');
            const toggleBtns = document.querySelectorAll('.toggle-btn');

            loginForm.classList.add('hidden');
            signupForm.classList.remove('hidden');

            toggleBtns[0].classList.remove('active');
            toggleBtns[1].classList.add('active');

            document.querySelector('.form-title').textContent = 'Create Account';
            document.querySelector('.form-subtitle').textContent = 'Sign up to get started';
        }

        // Social login function
        function socialLogin(provider) {
            if (provider === 'google') {
                window.location.href = '/auth/google';
            } else if (provider === 'facebook') {
                alert('Facebook login is not configured yet. Please use Google or email signup.');
            }
        }

        // Form validation
        document.getElementById('signupForm').addEventListener('submit', function (e) {
            const password = this.querySelector('input[name="password"]').value;
            const confirmPassword = this.querySelector('input[name="confirmPassword"]').value;

            if (password !== confirmPassword) {
                e.preventDefault();
                alert('Passwords do not match!');
            }
        });

        // Page load animation
        document.querySelector('.container').style.opacity = '0';
        document.querySelector('.container').style.transform = 'scale(0.95)';

        setTimeout(function () {
            document.querySelector('.container').style.transition = 'all 0.6s ease';
            document.querySelector('.container').style.opacity = '1';
            document.querySelector('.container').style.transform = 'scale(1)';
        }, 100);
    </script>
</body>

</html>
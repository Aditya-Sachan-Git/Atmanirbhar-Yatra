<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - Atmanirbhar Yatra</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0a0a0a;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .container {
            max-width: 500px;
            width: 90%;
            background: #111111;
            border-radius: 24px;
            padding: 50px 40px;
            box-shadow: 0 25px 80px rgba(255, 107, 53, 0.2);
            border: 1px solid rgba(255, 107, 53, 0.1);
        }

        h1 {
            color: white;
            font-size: 2rem;
            margin-bottom: 10px;
            text-align: center;
        }

        p {
            color: #888;
            text-align: center;
            margin-bottom: 30px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-input {
            width: 100%;
            padding: 14px 18px;
            background: rgba(51, 65, 85, 0.3);
            border: 2px solid rgba(148, 163, 184, 0.2);
            border-radius: 10px;
            color: white;
            font-size: 0.95rem;
            transition: all 0.3s ease;
        }

        .form-input:focus {
            outline: none;
            border-color: #ff6b35;
            box-shadow: 0 0 20px rgba(96, 165, 250, 0.2);
        }

        .form-btn {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #ff6b35, #f7931e);
            border: none;
            border-radius: 12px;
            color: white;
            font-size: 1.05rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .form-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 40px rgba(255, 107, 53, 0.4);
        }

        .message {
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
            text-align: center;
            background: #fee;
            border: 2px solid #f88;
            color: #c33;
        }
    </style>
</head>

<body>
    <div class="container">
        <h1>Reset Your Password 🔑</h1>
        <p>Enter your new password below.</p>

        <% if (typeof error !=='undefined' && error) { %>
            <div class="message">
                <%= error %>
            </div>
            <% } %>

                <form action="/reset-password/<%= token %>" method="POST">
                    <div class="form-group">
                        <input type="password" class="form-input" name="password"
                            placeholder="New Password (min 4 chars)" minlength="4" required>
                    </div>
                    <div class="form-group">
                        <input type="password" class="form-input" name="confirmPassword"
                            placeholder="Confirm New Password" required>
                    </div>
                    <button type="submit" class="form-btn">
                        <i class="fas fa-check"></i> Reset Password
                    </button>
                </form>
    </div>
</body>

</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Complete Your Tour Booking</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0f0f0f 0%, #1a1a1a 50%, #0f0f0f 100%);
            min-height: 100vh;
            padding: 20px;
            color: #ffffff;
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(circle at 20% 50%, rgba(120, 119, 198, 0.1), transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(255, 119, 198, 0.1), transparent 50%),
                radial-gradient(circle at 40% 80%, rgba(120, 255, 198, 0.1), transparent 50%);
            pointer-events: none;
            z-index: -1;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
            background: rgba(15, 15, 15, 0.95);
            border-radius: 24px;
            box-shadow: 
                0 25px 50px rgba(0, 0, 0, 0.5),
                0 0 0 1px rgba(255, 255, 255, 0.1),
                inset 0 1px 0 rgba(255, 255, 255, 0.1);
            overflow: hidden;
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .header {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            color: white;
            padding: 40px 30px;
            text-align: center;
            position: relative;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 30% 20%, rgba(120, 119, 198, 0.2), transparent 30%),
                radial-gradient(circle at 70% 80%, rgba(255, 119, 198, 0.2), transparent 30%);
        }

        .header h1 {
            font-size: 2.8rem;
            margin-bottom: 15px;
            position: relative;
            z-index: 1;
            font-weight: 700;
            background: linear-gradient(135deg, #ffffff, #a0a0a0);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .header p {
            font-size: 1.2rem;
            opacity: 0.8;
            position: relative;
            z-index: 1;
            color: #b0b0b0;
        }

        .selected-places {
            background: rgba(255, 255, 255, 0.05);
            margin: 25px 0;
            padding: 20px;
            border-radius: 16px;
            position: relative;
            z-index: 1;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .selected-places h3 {
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 1.1rem;
            color: #ffffff;
        }

        .places-list {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .place-tag {
            background: linear-gradient(135deg, rgba(120, 119, 198, 0.3), rgba(255, 119, 198, 0.3));
            padding: 8px 16px;
            border-radius: 25px;
            font-size: 0.9rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: #ffffff;
            font-weight: 500;
        }

        .form-container {
            padding: 50px 40px;
            background: rgba(10, 10, 10, 0.8);
        }

        .progress-bar {
            width: 100%;
            height: 8px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
            margin-bottom: 40px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #7c77c6, #ff77c6);
            width: 20%;
            transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            border-radius: 4px;
            box-shadow: 0 0 20px rgba(120, 119, 198, 0.5);
        }

        .form-section {
            display: none;
            animation: slideIn 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .form-section.active {
            display: block;
        }

        @keyframes slideIn {
            from { 
                opacity: 0; 
                transform: translateX(30px); 
            }
            to { 
                opacity: 1; 
                transform: translateX(0); 
            }
        }

        .section-title {
            font-size: 2rem;
            color: #ffffff;
            margin-bottom: 30px;
            display: flex;
            align-items: center;
            gap: 20px;
            font-weight: 600;
        }

        .section-icon {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #7c77c6, #ff77c6);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.4rem;
            box-shadow: 0 8px 25px rgba(120, 119, 198, 0.3);
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            margin-bottom: 35px;
        }

        .form-group {
            position: relative;
        }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

        .form-label {
            display: block;
            margin-bottom: 10px;
            font-weight: 600;
            color: #ffffff;
            font-size: 1rem;
        }

        .form-input, .form-select, .form-textarea {
            width: 100%;
            padding: 16px 20px;
            border: 2px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            font-size: 1rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: rgba(255, 255, 255, 0.05);
            color: #ffffff;
            backdrop-filter: blur(10px);
        }

        .form-input::placeholder {
            color: rgba(255, 255, 255, 0.5);
        }

        .form-input:focus, .form-select:focus, .form-textarea:focus {
            outline: none;
            border-color: #7c77c6;
            box-shadow: 
                0 0 0 4px rgba(124, 119, 198, 0.1),
                0 8px 25px rgba(124, 119, 198, 0.2);
            transform: translateY(-2px);
            background: rgba(255, 255, 255, 0.08);
        }

        .form-textarea {
            resize: vertical;
            min-height: 120px;
        }

        .checkbox-group, .radio-group {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 15px;
            margin-top: 15px;
        }

        .checkbox-item, .radio-item {
            display: flex;
            align-items: center;
            padding: 16px 20px;
            border: 2px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
        }

        .checkbox-item:hover, .radio-item:hover {
            border-color: #7c77c6;
            background: rgba(124, 119, 198, 0.1);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(124, 119, 198, 0.2);
        }

        .checkbox-item input, .radio-item input {
            margin-right: 12px;
            transform: scale(1.3);
            accent-color: #7c77c6;
        }

        .budget-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .budget-card {
            padding: 25px 20px;
            border: 2px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            text-align: center;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
        }

        .budget-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(124, 119, 198, 0.3);
            border-color: #7c77c6;
        }

        .budget-card input[type="radio"] {
            position: absolute;
            opacity: 0;
        }

        .budget-card input[type="radio"]:checked + .budget-content {
            background: linear-gradient(135deg, #7c77c6, #ff77c6);
            color: white;
            box-shadow: 0 0 30px rgba(124, 119, 198, 0.5);
        }

        .budget-content {
            border-radius: 12px;
            padding: 15px;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .budget-amount {
            font-size: 1.3rem;
            font-weight: bold;
            margin-bottom: 8px;
        }

        .budget-desc {
            font-size: 0.95rem;
            opacity: 0.8;
        }

        .passenger-card {
            border: 2px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 25px;
            margin-bottom: 25px;
            position: relative;
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
        }

        .passenger-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .passenger-number {
            background: linear-gradient(135deg, #7c77c6, #ff77c6);
            color: white;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(124, 119, 198, 0.3);
        }

        .lead-badge {
            background: linear-gradient(135deg, #f39c12, #e67e22);
            color: white;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(243, 156, 18, 0.3);
        }

        .navigation {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 50px;
            padding-top: 30px;
            border-top: 2px solid rgba(255, 255, 255, 0.1);
        }

        .btn {
            padding: 16px 35px;
            border: none;
            border-radius: 30px;
            font-size: 1.05rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            position: relative;
            overflow: hidden;
        }

        .btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.6s;
        }

        .btn:hover::before {
            left: 100%;
        }

        .btn-primary {
            background: linear-gradient(135deg, #7c77c6, #ff77c6);
            color: white;
            box-shadow: 0 8px 25px rgba(124, 119, 198, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(124, 119, 198, 0.4);
        }

        .btn-secondary {
            background: transparent;
            color: #7c77c6;
            border: 2px solid #7c77c6;
        }

        .btn-secondary:hover {
            background: #7c77c6;
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(124, 119, 198, 0.3);
        }

        .btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            transform: none !important;
        }

        .cost-estimate {
            background: linear-gradient(135deg, #2ecc71, #27ae60);
            color: white;
            padding: 30px;
            border-radius: 16px;
            text-align: center;
            margin: 25px 0;
            box-shadow: 0 15px 40px rgba(46, 204, 113, 0.3);
        }

        .cost-amount {
            font-size: 2.5rem;
            font-weight: bold;
            margin-bottom: 8px;
        }

        .cost-note {
            font-size: 1rem;
            opacity: 0.9;
        }

        /* Enhanced form select styling */
        .form-select {
            appearance: none;
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
            background-position: right 12px center;
            background-repeat: no-repeat;
            background-size: 16px;
            padding-right: 40px;
        }

        .form-select option {
            background: #1a1a1a;
            color: #ffffff;
        }

        /* Scrollbar styling */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.1);
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, #7c77c6, #ff77c6);
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(135deg, #6b66b3, #e666b3);
        }

        @media (max-width: 768px) {
            .form-container {
                padding: 30px 20px;
            }
            
            .form-grid {
                grid-template-columns: 1fr;
            }
            
            .checkbox-group, .radio-group {
                grid-template-columns: 1fr;
            }
            
            .budget-cards {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .navigation {
                flex-direction: column;
                gap: 20px;
            }

            .header h1 {
                font-size: 2.2rem;
            }

            .section-title {
                font-size: 1.6rem;
            }
        }

        @media (max-width: 480px) {
            .budget-cards {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1><i class="fas fa-map-marked-alt"></i> Complete Your Tour Booking</h1>
            <p>Fill out the details below to get a personalized quote for your dream trip</p>
            
            <div class="selected-places">
                <h3><i class="fas fa-map-pin"></i> Selected Destinations</h3>
                <div class="places-list" id="selectedPlaces">
                    <% if (typeof selectedPlaces !== 'undefined' && selectedPlaces.length > 0) { %>
                        <% selectedPlaces.forEach(place => { %>
                            <span class="place-tag"><%= place %></span>
                        <% }) %>
                    <% } else { %>
                        <span class="place-tag">No destinations selected</span>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="form-container">
            <div class="progress-bar">
                <div class="progress-fill" id="progressFill"></div>
            </div>

            <form id="tourBookingForm" method="post" action="/submit-booking">
                <!-- Section 1: Trip Details -->
                <div class="form-section active" id="section1">
                    <div class="section-title">
                        <div class="section-icon"><i class="fas fa-route"></i></div>
                        <span>Trip Details</span>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">Start Point *</label>
                            <input type="text" name="startPoint" class="form-input" placeholder="Your departure city" 
                                   value="<%= typeof formData !== 'undefined' && formData.startPoint ? formData.startPoint : '' %>" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">End Point *</label>
                            <input type="text" name="endPoint" class="form-input" placeholder="Where you'll return to" 
                                   value="<%= typeof formData !== 'undefined' && formData.endPoint ? formData.endPoint : '' %>" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Start Date *</label>
                            <input type="date" name="startDate" class="form-input" 
                                   value="<%= typeof formData !== 'undefined' && formData.startDate ? formData.startDate : '' %>" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">End Date *</label>
                            <input type="date" name="endDate" class="form-input" 
                                   value="<%= typeof formData !== 'undefined' && formData.endDate ? formData.endDate : '' %>" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Total Persons *</label>
                            <input type="number" name="totalPersons" class="form-input" min="1" max="50" placeholder="Number of travelers" 
                                   value="<%= typeof formData !== 'undefined' && formData.totalPersons ? formData.totalPersons : '' %>" required>
                        </div>
                    </div>
                </div>

                <!-- Section 2: Accommodation & Transport -->
                <div class="form-section" id="section2">
                    <div class="section-title">
                        <div class="section-icon"><i class="fas fa-bed"></i></div>
                        <span>Accommodation & Transport</span>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">Accommodation Type *</label>
                            <select name="accommodationType" class="form-select" required>
                                <option value="">Choose accommodation level</option>
                                <option value="Budget" <%= typeof formData !== 'undefined' && formData.accommodationType === 'Budget' ? 'selected' : '' %>>Budget - Basic hotels/guesthouses</option>
                                <option value="Standard" <%= typeof formData !== 'undefined' && formData.accommodationType === 'Standard' ? 'selected' : '' %>>Standard - 3-star hotels</option>
                                <option value="Luxury" <%= typeof formData !== 'undefined' && formData.accommodationType === 'Luxury' ? 'selected' : '' %>>Luxury - 4-star hotels</option>
                                <option value="Premium" <%= typeof formData !== 'undefined' && formData.accommodationType === 'Premium' ? 'selected' : '' %>>Premium - 5-star hotels & resorts</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Preferred Transport *</label>
                            <select name="transportMode" class="form-select" required>
                                <option value="">Select transport mode</option>
                                <option value="Flight" <%= typeof formData !== 'undefined' && formData.transportMode === 'Flight' ? 'selected' : '' %>>Flight</option>
                                <option value="Train" <%= typeof formData !== 'undefined' && formData.transportMode === 'Train' ? 'selected' : '' %>>Train</option>
                                <option value="Bus" <%= typeof formData !== 'undefined' && formData.transportMode === 'Bus' ? 'selected' : '' %>>Bus</option>
                                <option value="Car/Taxi" <%= typeof formData !== 'undefined' && formData.transportMode === 'Car/Taxi' ? 'selected' : '' %>>Car/Taxi</option>
                                <option value="Mixed" <%= typeof formData !== 'undefined' && formData.transportMode === 'Mixed' ? 'selected' : '' %>>Mixed (Multiple modes)</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Room Preferences</label>
                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">Single Rooms</label>
                                <input type="number" name="singleRooms" class="form-input" min="0" 
                                       value="<%= typeof formData !== 'undefined' && formData.singleRooms ? formData.singleRooms : '0' %>">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Double Rooms</label>
                                <input type="number" name="doubleRooms" class="form-input" min="0" 
                                       value="<%= typeof formData !== 'undefined' && formData.doubleRooms ? formData.doubleRooms : '0' %>">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Triple Rooms</label>
                                <input type="number" name="tripleRooms" class="form-input" min="0" 
                                       value="<%= typeof formData !== 'undefined' && formData.tripleRooms ? formData.tripleRooms : '0' %>">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Family Rooms</label>
                                <input type="number" name="familyRooms" class="form-input" min="0" 
                                       value="<%= typeof formData !== 'undefined' && formData.familyRooms ? formData.familyRooms : '0' %>">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Section 3: Food & Services -->
                <div class="form-section" id="section3">
                    <div class="section-title">
                        <div class="section-icon"><i class="fas fa-utensils"></i></div>
                        <span>Food & Additional Services</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Meal Preferences</label>
                        <div class="checkbox-group">
                            <div class="checkbox-item">
                                <input type="checkbox" name="meals" value="breakfast" id="breakfast" 
                                       <%= typeof formData !== 'undefined' && formData.meals && formData.meals.includes('breakfast') ? 'checked' : 'checked' %>>
                                <label for="breakfast">Breakfast</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="meals" value="lunch" id="lunch"
                                       <%= typeof formData !== 'undefined' && formData.meals && formData.meals.includes('lunch') ? 'checked' : '' %>>
                                <label for="lunch">Lunch</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="meals" value="dinner" id="dinner"
                                       <%= typeof formData !== 'undefined' && formData.meals && formData.meals.includes('dinner') ? 'checked' : '' %>>
                                <label for="dinner">Dinner</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Dietary Restrictions</label>
                        <div class="checkbox-group">
                            <div class="checkbox-item">
                                <input type="checkbox" name="dietaryRestrictions" value="Vegetarian" id="vegetarian"
                                       <%= typeof formData !== 'undefined' && formData.dietaryRestrictions && formData.dietaryRestrictions.includes('Vegetarian') ? 'checked' : '' %>>
                                <label for="vegetarian">Vegetarian</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="dietaryRestrictions" value="Vegan" id="vegan"
                                       <%= typeof formData !== 'undefined' && formData.dietaryRestrictions && formData.dietaryRestrictions.includes('Vegan') ? 'checked' : '' %>>
                                <label for="vegan">Vegan</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="dietaryRestrictions" value="Halal" id="halal"
                                       <%= typeof formData !== 'undefined' && formData.dietaryRestrictions && formData.dietaryRestrictions.includes('Halal') ? 'checked' : '' %>>
                                <label for="halal">Halal</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="dietaryRestrictions" value="Gluten-Free" id="glutenFree"
                                       <%= typeof formData !== 'undefined' && formData.dietaryRestrictions && formData.dietaryRestrictions.includes('Gluten-Free') ? 'checked' : '' %>>
                                <label for="glutenFree">Gluten-Free</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Additional Services</label>
                        <div class="checkbox-group">
                            <div class="checkbox-item">
                                <input type="checkbox" name="additionalServices" value="Tour Guide" id="tourGuide"
                                       <%= typeof formData !== 'undefined' && formData.additionalServices && formData.additionalServices.includes('Tour Guide') ? 'checked' : '' %>>
                                <label for="tourGuide">Professional Tour Guide</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="additionalServices" value="Photography" id="photography"
                                       <%= typeof formData !== 'undefined' && formData.additionalServices && formData.additionalServices.includes('Photography') ? 'checked' : '' %>>
                                <label for="photography">Photography Service</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="additionalServices" value="Adventure Activities" id="adventure"
                                       <%= typeof formData !== 'undefined' && formData.additionalServices && formData.additionalServices.includes('Adventure Activities') ? 'checked' : '' %>>
                                <label for="adventure">Adventure Activities</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="additionalServices" value="Cultural Experiences" id="cultural"
                                       <%= typeof formData !== 'undefined' && formData.additionalServices && formData.additionalServices.includes('Cultural Experiences') ? 'checked' : '' %>>
                                <label for="cultural">Cultural Experiences</label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Section 4: Budget -->
                <div class="form-section" id="section4">
                    <div class="section-title">
                        <div class="section-icon"><i class="fas fa-wallet"></i></div>
                        <span>Budget Range</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">What's your budget range per person? *</label>
                        <div class="budget-cards">
                            <div class="budget-card">
                                <input type="radio" name="budgetRange" value="Under 20K" id="budget1" required
                                       <%= typeof formData !== 'undefined' && formData.budgetRange === 'Under 20K' ? 'checked' : '' %>>
                                <div class="budget-content">
                                    <div class="budget-amount">Under ₹20K</div>
                                    <div class="budget-desc">Budget Travel</div>
                                </div>
                            </div>
                            <div class="budget-card">
                                <input type="radio" name="budgetRange" value="20K-50K" id="budget2"
                                       <%= typeof formData !== 'undefined' && formData.budgetRange === '20K-50K' ? 'checked' : '' %>>
                                <div class="budget-content">
                                    <div class="budget-amount">₹20K - ₹50K</div>
                                    <div class="budget-desc">Standard</div>
                                </div>
                            </div>
                            <div class="budget-card">
                                <input type="radio" name="budgetRange" value="50K-1L" id="budget3"
                                       <%= typeof formData !== 'undefined' && formData.budgetRange === '50K-1L' ? 'checked' : '' %>>
                                <div class="budget-content">
                                    <div class="budget-amount">₹50K - ₹1L</div>
                                    <div class="budget-desc">Comfortable</div>
                                </div>
                            </div>
                            <div class="budget-card">
                                <input type="radio" name="budgetRange" value="1L-2L" id="budget4"
                                       <%= typeof formData !== 'undefined' && formData.budgetRange === '1L-2L' ? 'checked' : '' %>>
                                <div class="budget-content">
                                    <div class="budget-amount">₹1L - ₹2L</div>
                                    <div class="budget-desc">Luxury</div>
                                </div>
                            </div>
                            <div class="budget-card">
                                <input type="radio" name="budgetRange" value="Above 5L" id="budget5"
                                       <%= typeof formData !== 'undefined' && formData.budgetRange === 'Above 5L' ? 'checked' : '' %>>
                                <div class="budget-content">
                                    <div class="budget-amount">Above ₹5L</div>
                                    <div class="budget-desc">Ultra Luxury</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Section 5: Passenger Details -->
                <div class="form-section" id="section5">
                    <div class="section-title">
                        <div class="section-icon"><i class="fas fa-users"></i></div>
                        <span>Passenger Details</span>
                    </div>

                    <div id="passengerDetails">
                        <!-- Passenger cards will be generated dynamically -->
                        <div class="passenger-card">
                            <div class="passenger-header">
                                <div class="passenger-number">1</div>
                                <div class="lead-badge">Lead Passenger</div>
                            </div>
                            <div class="form-grid">
                                <div class="form-group">
                                    <label class="form-label">Full Name *</label>
                                    <input type="text" name="passenger_1_name" class="form-input" placeholder="Enter full name" required>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Email *</label>
                                    <input type="email" name="passenger_1_email" class="form-input" placeholder="Email address" required>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Phone *</label>
                                    <input type="tel" name="passenger_1_phone" class="form-input" placeholder="Phone number" required>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Age *</label>
                                    <input type="number" name="passenger_1_age" class="form-input" min="1" max="120" placeholder="Age" required>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Gender *</label>
                                    <select name="passenger_1_gender" class="form-select" required>
                                        <option value="">Select gender</option>
                                        <option value="Male">Male</option>
                                        <option value="Female">Female</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Section 6: Special Requirements -->
                <div class="form-section" id="section6">
                    <div class="section-title">
                        <div class="section-icon"><i class="fas fa-clipboard-list"></i></div>
                        <span>Special Requirements</span>
                    </div>

                    <div class="form-grid">
                        <div class="form-group full-width">
                            <label class="form-label">Special Requests or Requirements</label>
                            <textarea name="specialRequests" class="form-textarea" 
                                      placeholder="Any special requests, accessibility needs, medical requirements, or other important information we should know..."><%= typeof formData !== 'undefined' && formData.specialRequests ? formData.specialRequests : '' %></textarea>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Emergency Contact Name</label>
                            <input type="text" name="emergencyContactName" class="form-input" placeholder="Full name"
                                   value="<%= typeof formData !== 'undefined' && formData.emergencyContactName ? formData.emergencyContactName : '' %>">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Emergency Contact Phone</label>
                            <input type="tel" name="emergencyContactPhone" class="form-input" placeholder="Phone number"
                                   value="<%= typeof formData !== 'undefined' && formData.emergencyContactPhone ? formData.emergencyContactPhone : '' %>">
                        </div>
                    </div>
                </div>

                <!-- Section 7: Review & Submit -->
                <div class="form-section" id="section7">
                    <div class="section-title">
                        <div class="section-icon"><i class="fas fa-check-circle"></i></div>
                        <span>Review & Submit</span>
                    </div>

                    <div class="cost-estimate">
                        <div class="cost-amount" id="estimatedCost">₹0</div>
                        <div class="cost-note">Estimated total cost (subject to confirmation)</div>
                    </div>

                    <div class="form-group">
                        <div class="checkbox-item">
                            <input type="checkbox" name="termsAccepted" id="terms" required>
                            <label for="terms">I agree to the terms and conditions and privacy policy *</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="checkbox-item">
                            <input type="checkbox" name="marketingConsent" id="marketing">
                            <label for="marketing">I would like to receive promotional offers and travel updates via email</label>
                        </div>
                    </div>
                </div>

                <div class="navigation">
                    <button type="button" class="btn btn-secondary" id="prevBtn" onclick="changeSection(-1)">
                        <i class="fas fa-arrow-left"></i> Previous
                    </button>
                    <div class="step-indicator">
                        <span id="currentStep">1</span> of <span id="totalSteps">7</span>
                    </div>
                    <button type="button" class="btn btn-primary" id="nextBtn" onclick="changeSection(1)">
                        Next <i class="fas fa-arrow-right"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        let currentSection = 1;
        const totalSections = 7;
        const progressFill = document.getElementById('progressFill');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        const currentStepSpan = document.getElementById('currentStep');
        const totalStepsSpan = document.getElementById('totalSteps');

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            updateSectionDisplay();
            updateProgressBar();
            updateStepIndicator();
            generatePassengerForms();
            calculateEstimatedCost();
            
            // Set minimum date to today
            const today = new Date().toISOString().split('T')[0];
            document.getElementsByName('startDate')[0].setAttribute('min', today);
            document.getElementsByName('endDate')[0].setAttribute('min', today);
        });

        function changeSection(direction) {
            if (direction === 1 && currentSection < totalSections) {
                if (validateCurrentSection()) {
                    currentSection++;
                    updateSectionDisplay();
                    updateProgressBar();
                    updateStepIndicator();
                    
                    if (currentSection === 5) {
                        generatePassengerForms();
                    }
                    if (currentSection === 7) {
                        updateReviewSection();
                    }
                }
            } else if (direction === -1 && currentSection > 1) {
                currentSection--;
                updateSectionDisplay();
                updateProgressBar();
                updateStepIndicator();
            }
        }

        function updateSectionDisplay() {
            // Hide all sections
            document.querySelectorAll('.form-section').forEach(section => {
                section.classList.remove('active');
            });
            
            // Show current section
            document.getElementById(`section${currentSection}`).classList.add('active');
            
            // Update button states
            prevBtn.style.display = currentSection === 1 ? 'none' : 'flex';
            
            if (currentSection === totalSections) {
                nextBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Submit Booking';
                nextBtn.type = 'submit';
            } else {
                nextBtn.innerHTML = 'Next <i class="fas fa-arrow-right"></i>';
                nextBtn.type = 'button';
            }
        }

        function updateProgressBar() {
            const progress = (currentSection / totalSections) * 100;
            progressFill.style.width = `${progress}%`;
        }

        function updateStepIndicator() {
            currentStepSpan.textContent = currentSection;
            totalStepsSpan.textContent = totalSections;
        }

        function validateCurrentSection() {
            const currentSectionElement = document.getElementById(`section${currentSection}`);
            const requiredFields = currentSectionElement.querySelectorAll('[required]');
            
            let isValid = true;
            requiredFields.forEach(field => {
                if (!field.value.trim()) {
                    field.style.borderColor = '#ff6b6b';
                    isValid = false;
                } else {
                    field.style.borderColor = '';
                }
            });
            
            if (!isValid) {
                // Smooth scroll to first invalid field
                const firstInvalid = currentSectionElement.querySelector('[required]:invalid, [required][style*="border-color: rgb(255, 107, 107)"]');
                if (firstInvalid) {
                    firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    firstInvalid.focus();
                }
            }
            
            return isValid;
        }

        function generatePassengerForms() {
            const totalPersons = parseInt(document.getElementsByName('totalPersons')[0].value) || 1;
            const container = document.getElementById('passengerDetails');
            
            // Keep only the first passenger card (lead passenger)
            const leadCard = container.querySelector('.passenger-card');
            container.innerHTML = '';
            container.appendChild(leadCard);
            
            // Generate additional passenger cards
            for (let i = 2; i <= totalPersons; i++) {
                const passengerCard = document.createElement('div');
                passengerCard.className = 'passenger-card';
                passengerCard.innerHTML = `
                    <div class="passenger-header">
                        <div class="passenger-number">${i}</div>
                    </div>
                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">Full Name *</label>
                            <input type="text" name="passenger_${i}_name" class="form-input" placeholder="Enter full name" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Age *</label>
                            <input type="number" name="passenger_${i}_age" class="form-input" min="1" max="120" placeholder="Age" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Gender *</label>
                            <select name="passenger_${i}_gender" class="form-select" required>
                                <option value="">Select gender</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>
                `;
                container.appendChild(passengerCard);
            }
        }

        function calculateEstimatedCost() {
            // Simple cost calculation based on selections
            const totalPersons = parseInt(document.getElementsByName('totalPersons')[0].value) || 1;
            const budgetRange = document.querySelector('input[name="budgetRange"]:checked')?.value;
            
            let baseCost = 0;
            switch (budgetRange) {
                case 'Under 20K': baseCost = 15000; break;
                case '20K-50K': baseCost = 35000; break;
                case '50K-1L': baseCost = 75000; break;
                case '1L-2L': baseCost = 150000; break;
                case 'Above 5L': baseCost = 500000; break;
                default: baseCost = 35000;
            }
            
            const totalCost = baseCost * totalPersons;
            document.getElementById('estimatedCost').textContent = `₹${totalCost.toLocaleString('en-IN')}`;
        }

        function updateReviewSection() {
            calculateEstimatedCost();
        }

        // Add event listeners for real-time updates
        document.addEventListener('change', function(e) {
            if (e.target.name === 'totalPersons' && currentSection === 5) {
                generatePassengerForms();
            }
            if (e.target.name === 'budgetRange') {
                calculateEstimatedCost();
            }
        });

        // Form submission handling
        document.getElementById('tourBookingForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            if (validateCurrentSection()) {
                // Show loading state
                nextBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Submitting...';
                nextBtn.disabled = true;
                
                // Simulate form submission (replace with actual submission logic)
                setTimeout(() => {
                    alert('Thank you! Your booking request has been submitted. We will contact you shortly with a detailed quote.');
                    // Reset form or redirect
                    // window.location.href = '/booking-confirmation';
                }, 2000);
            }
        });

        // Auto-populate selected places from URL parameters or localStorage
        function populateSelectedPlaces() {
            const urlParams = new URLSearchParams(window.location.search);
            const places = urlParams.get('places');
            
            if (places) {
                const placesList = places.split(',');
                const container = document.getElementById('selectedPlaces');
                container.innerHTML = '';
                
                placesList.forEach(place => {
                    const tag = document.createElement('span');
                    tag.className = 'place-tag';
                    tag.textContent = decodeURIComponent(place.trim());
                    container.appendChild(tag);
                });
            }
        }

        // Call on page load
        populateSelectedPlaces();
    </script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Email Verification Required - Atmanirbhar Yatra</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background: #0a0a0a;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .container {
            max-width: 600px;
            width: 90%;
            background: #111111;
            border-radius: 24px;
            padding: 60px 40px;
            text-align: center;
            box-shadow: 0 25px 80px rgba(255, 107, 53, 0.2);
            border: 1px solid rgba(255, 107, 53, 0.1);
        }

        .icon {
            font-size: 5rem;
            color: #f59e0b;
            margin-bottom: 30px;
        }

        h1 {
            color: white;
            font-size: 2rem;
            margin-bottom: 20px;
        }

        p {
            color: #888;
            font-size: 1.1rem;
            line-height: 1.6;
            margin-bottom: 15px;
        }

        .email {
            color: #ff6b35;
            font-weight: 600;
        }

        .warning {
            background: rgba(245, 158, 11, 0.1);
            border: 2px solid #f59e0b;
            border-radius: 12px;
            padding: 20px;
            margin: 30px 0;
        }

        .warning p {
            color: #fbbf24;
        }

        form {
            margin-top: 30px;
        }

        .btn {
            display: inline-block;
            padding: 16px 40px;
            background: linear-gradient(135deg, #ff6b35, #f7931e);
            color: white;
            text-decoration: none;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            margin: 10px;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(255, 107, 53, 0.4);
        }

        .btn-secondary {
            background: transparent;
            border: 2px solid rgba(255, 107, 53, 0.3);
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="icon">
            <i class="fas fa-exclamation-circle"></i>
        </div>
        <h1>Email Verification Required ⚠️</h1>
        <div class="warning">
            <p>
                <%= message %>
            </p>
        </div>
        <p>We sent a verification email to:</p>
        <p class="email">
            <%= email %>
        </p>
        <p>Please check your inbox (and spam folder) and click the verification link.</p>

        <form action="/resend-verification" method="POST" style="display: inline;">
            <input type="hidden" name="email" value="<%= email %>">
            <button type="submit" class="btn">
                <i class="fas fa-redo"></i> Resend Verification Email
            </button>
        </form>
        <a href="/login" class="btn btn-secondary">Back to Login</a>
    </div>
</body>

</html>
          <div class="destination-overlay">
            <div class="destination-name">Northeast Beauty</div>
            <div class="destination-desc">Scotland of the East with rolling hills and pristine nature</div>
          </div>
        </div>

        <div class="destination-card">
          <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQyPYtMUhbFFtmWhiqjYGX79FctD5sDa072cw&s" alt="Coastal Beauty">

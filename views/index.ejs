<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Atmanirbhar Yatra - Your Custom Travel Experience</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">
  <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #0a0a0a;
      color: #ffffff;
      font-family: 'Montserrat', sans-serif;
      overflow-x: hidden;
    }

    /* Header */
    header {
      position: fixed;
      top: 0;
      width: 100%;
      padding: 1rem 3rem;
      background: rgba(0, 0, 0, 0.9);
      backdrop-filter: blur(10px);
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 1000;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .logo {
      display: flex;
      align-items: center;
      font-size: 1.5rem;
      font-weight: 700;
      color: #ff6b35;
    }

    .logo img {
      width: 35px;
      height: 35px;
      margin-right: 10px;
      filter: brightness(0) saturate(100%) invert(45%) sepia(76%) saturate(2468%) hue-rotate(346deg) brightness(101%) contrast(101%);
    }

    nav ul {
      display: flex;
      list-style: none;
      gap: 2rem;
    }

    nav a {
      color: #ffffff;
      text-decoration: none;
      transition: color 0.3s ease;
      font-weight: 500;
    }

    nav a:hover {
      color: #ff6b35;
    }

    .header-right {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .header-right a {
      color: #ffffff;
      font-size: 1.2rem;
      transition: color 0.3s ease;
    }

    .header-right a:hover {
      color: #ff6b35;
    }

    .btn {
      background: linear-gradient(135deg, #ff6b35, #f7931e);
      padding: 0.7rem 1.5rem;
      border-radius: 25px;
      text-decoration: none;
      color: white !important;
      font-weight: 600;
      transition: transform 0.3s ease;
    }

    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(255, 107, 53, 0.3);
    }

    /* Hero Section */
    .hero {
      height: 100vh;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.6)), 
                  url('https://vagatrip.com/storage/blogs/April2023/cover-10.jpg');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
    }

    .hero-content {
      text-align: center;
      max-width: 800px;
      padding: 0 2rem;
      animation: fadeInUp 1s ease-out;
    }

    .hero-subtitle {
      font-size: 1.2rem;
      color: #ff6b35;
      margin-bottom: 1rem;
      font-weight: 500;
      letter-spacing: 3px;
    }

    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: 4rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      background: linear-gradient(135deg, #ffffff, #ff6b35);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1.2;
    }

    .hero-description {
      font-size: 1.3rem;
      margin-bottom: 3rem;
      color: #e0e0e0;
      line-height: 1.6;
    }

    .cta-buttons {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .cta-primary, .cta-secondary {
      padding: 1rem 2rem;
      border-radius: 30px;
      text-decoration: none;
      font-weight: 600;
      font-size: 1.1rem;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .cta-primary {
      background: linear-gradient(135deg, #ff6b35, #f7931e);
      color: white;
    }

    .cta-secondary {
      background: transparent;
      color: white;
      border: 2px solid #ff6b35;
    }

    .cta-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 15px 30px rgba(255, 107, 53, 0.4);
    }

    .cta-secondary:hover {
      background: #ff6b35;
      transform: translateY(-3px);
    }

    /* USP Section */
    .usp-section {
      padding: 6rem 3rem;
      background: #111111;
    }

    .section-title {
      text-align: center;
      font-family: 'Playfair Display', serif;
      font-size: 3rem;
      margin-bottom: 1rem;
      color: #ff6b35;
    }

    .section-subtitle {
      text-align: center;
      font-size: 1.2rem;
      color: #888;
      margin-bottom: 4rem;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    .usp-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 3rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .usp-card {
      background: rgba(255, 255, 255, 0.05);
      padding: 2.5rem;
      border-radius: 20px;
      text-align: center;
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 107, 53, 0.2);
      transition: transform 0.3s ease;
    }

    .usp-card:hover {
      transform: translateY(-10px);
      border-color: #ff6b35;
    }

    .usp-icon {
      font-size: 3rem;
      color: #ff6b35;
      margin-bottom: 1.5rem;
    }

    .usp-title {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 1rem;
    }

    .usp-description {
      color: #ccc;
      line-height: 1.6;
    }

    /* Destinations Gallery */
    .destinations {
      padding: 6rem 3rem;
      background: #0a0a0a;
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      max-width: 1400px;
      margin: 0 auto;
    }

    .destination-card {
      position: relative;
      height: 300px;
      border-radius: 20px;
      overflow: hidden;
      cursor: pointer;
      transition: transform 0.3s ease;
    }

    .destination-card:hover {
      transform: scale(1.05);
    }

    .destination-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.3s ease;
    }

    .destination-card:hover img {
      transform: scale(1.1);
    }

    .destination-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
      padding: 2rem;
      color: white;
    }

    .destination-name {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .destination-desc {
      font-size: 0.9rem;
      opacity: 0.9;
    }

    /* Custom Package Section */
    .custom-package {
      padding: 6rem 3rem;
      background: linear-gradient(135deg, #1a1a1a, #2a2a2a);
      text-align: center;
    }

    .package-content {
      max-width: 800px;
      margin: 0 auto;
    }

    .package-title {
      font-family: 'Playfair Display', serif;
      font-size: 3rem;
      margin-bottom: 1.5rem;
      background: linear-gradient(135deg, #ff6b35, #f7931e);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .package-description {
      font-size: 1.3rem;
      color: #ccc;
      margin-bottom: 3rem;
      line-height: 1.6;
    }

    .package-cta {
      background: linear-gradient(135deg, #ff6b35, #f7931e);
      color: white;
      padding: 1.2rem 3rem;
      border: none;
      border-radius: 30px;
      font-size: 1.2rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .package-cta:hover {
      transform: translateY(-3px);
      box-shadow: 0 20px 40px rgba(255, 107, 53, 0.4);
    }

    /* Chat Icon */
    .chat-icon {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      z-index: 1000;
    }

    .chat-icon a {
      display: block;
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg, #ff6b35, #f7931e);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 10px 30px rgba(255, 107, 53, 0.3);
      transition: transform 0.3s ease;
    }

    .chat-icon a:hover {
      transform: scale(1.1);
    }

    .chat-icon i {
      color: white;
      font-size: 1.5rem;
    }

    /* Animations */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(50px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Responsive */
    @media (max-width: 768px) {
      header {
        padding: 1rem;
      }

      .hero-title {
        font-size: 2.5rem;
      }

      .hero-description {
        font-size: 1.1rem;
      }

      .cta-buttons {
        flex-direction: column;
        align-items: center;
      }

      .section-title {
        font-size: 2.5rem;
      }

      .gallery-grid {
        grid-template-columns: 1fr;
      }

      nav ul {
        display: none;
      }
    }
  </style>
</head>
<body>
  <header>
    <div class="logo">
      <img src="https://imgs.search.brave.com/74fX-ravJ1uhsqHAKdolWlGAERZGXR-CTAliz9V6Nvk/rs:fit:860:0:0:0/g:ce/aHR0cHM6Ly9jZG4x/Lmljb25maW5kZXIu/Y29tL2RhdGEvaWNv/bnMvYm9rYm9rc3Rh/cnMtMTIxLWNsYXNz/aWMtc3RvY2staWNv/bnMtMS81MTIvYWly/cGxhbmUucG5n" alt="Atmanirbhar Yatra">
      Atmanirbhar Yatra
    </div>
    <nav>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/destinations">Destinations</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/hotel">Stays</a></li>
      </ul>
    </nav>
    <div class="header-right">
      <a href="#"><i class="fas fa-search"></i></a>
      <a href="#"><i class="fas fa-user"></i></a>
      <a href="/login" class="btn">Login</a>
    </div>
  </header>

  <main>
    <!-- Hero Section -->
    <section class="hero" id="home">
      <div class="hero-content">
        <div class="hero-subtitle">MOUNTAINS • BEACHES • CITIES • CULTURE</div>
